          <ul class="space-y-3">
            <li>
              <a href={personal.linkedin} target="_blank" rel="noopener" class="contact-link group">
                <span class="contact-icon group-hover:bg-[#0077B5]">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
