                  </svg>
                </span>
                <span class="text-xs">LinkedIn</span>
              </a>
            </li>
            <li>
              <a href={personal.github} target="_blank" rel="noopener" class="contact-link group">
                <span class="contact-icon group-hover:bg-slate-600">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                </span>
                <span class="text-xs">GitHub</span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Skills -->
        <div>
          <p class="sidebar-label">{t(lang, 'nav.skills')}</p>
          <div class="space-y-5">
            {skillGroups.map((group) => (
              <div>
                <p class="text-slate-500 text-xs mb-2.5 font-semibold uppercase tracking-wider">{lang === 'es' ? group.labelEs : group.labelEn}</p>
                <div class="flex flex-wrap gap-1.5">
                  {group.items.map((skill: {name: string}) => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-slate-800 text-slate-300 border border-slate-700 hover:bg-blue-600 hover:text-white hover:border-blue-500 transition-colors cursor-default font-mono">
                      {skill.name}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Idiomas -->
        <div>
          <p class="sidebar-label">{t(lang, 'section.languages')}</p>
          <div class="space-y-2">
            {languages.map((l) => (
              <div class="flex items-center justify-between">
                <span class="text-slate-300 text-sm">{l.name}</span>
                <span class="text-xs text-slate-500 bg-slate-800 px-2 py-0.5 rounded-full">
                  {lang === 'es' ? l.levelEs : l.levelEn}
                </span>
              </div>
            ))}
          </div>
        </div>


      </div>
    </aside>

    <!-- ══════════ MAIN ══════════ -->
    <main class="flex-1 min-w-0 px-6 py-10 lg:px-12 lg:py-12 space-y-8">

      <!-- About -->
      <section id="about" class="card scroll-mt-24">
        <h2 class="section-title">{t(lang, 'section.about')}</h2>
        {(lang === 'es' ? about.es : about.en).split('\n\n').map((para: string) => (
          <p class="text-slate-600 leading-relaxed mb-4 last:mb-0">{para}</p>
        ))}
        <div class="grid grid-cols-3 gap-4 mt-6 pt-6 border-t border-slate-100">
          <div class="text-center">
            <p class="text-2xl font-bold text-blue-600">{expYears}+</p>
            <p class="text-xs text-slate-500 mt-0.5">{lang === 'es' ? 'Años exp.' : 'Years exp.'}</p>
          </div>
          <div class="text-center border-x border-slate-100">
            <p class="text-2xl font-bold text-blue-600">{experiences.length}</p>
            <p class="text-xs text-slate-500 mt-0.5">{lang === 'es' ? 'Empresas' : 'Companies'}</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-blue-600">360°</p>
            <p class="text-xs text-slate-500 mt-0.5">{lang === 'es' ? 'Ciclo completo' : 'Full cycle'}</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 mt-6 pt-6 border-t border-slate-100">
          {preferences.map((p: {es:string;en:string;icon:string}) => (
            <div class="flex items-center gap-2 bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 hover:border-blue-200 hover:bg-blue-50 transition-colors">
              <span class="text-base">{p.icon}</span>
              <span class="text-slate-700 text-sm font-medium">{lang === 'es' ? p.es : p.en}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- Experience -->
      <section id="experience" class="card scroll-mt-24">
        <h2 class="section-title">{t(lang, 'section.experience')}</h2>
        <div class="divide-y divide-slate-50">
          {experiences.map((exp, i) => (
            <div class={`py-6 ${i === 0 ? 'pt-0' : ''}`}>
              <div class="flex items-start gap-4">
                <!-- Logo -->
                <a href={`https://${exp.domain}`} target="_blank" rel="noopener" class="shrink-0 w-11 h-11 rounded-xl overflow-hidden border border-slate-100 shadow-sm bg-white flex items-center justify-center transition-transform duration-200 hover:scale-110 hover:shadow-md">
                  <img
                    src={exp.logo || `https://logo.clearbit.com/${exp.domain}`}
                    alt={exp.company}
                    class="w-full h-full object-contain p-0.5"
                    onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
                  />
                  <span
                    class="w-full h-full items-center justify-center text-white text-xs font-bold rounded-xl"
                    style={`background-color:${exp.color};display:none`}
                  >
                    {initials(exp.company)}
                  </span>
                </a>

                <div class="flex-1 min-w-0">
                  <!-- Puesto primero: es lo que escanea el recruiter en el F-pattern -->
                  <div class="flex flex-wrap items-start justify-between gap-2 mb-0.5">
                    <div class="flex items-center gap-2 flex-wrap">
                      <h3 class="font-bold text-slate-900 text-base leading-snug">{lang === 'es' ? exp.roleEs : exp.roleEn}</h3>
                      {exp.current && (
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">
                          <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse inline-block"></span>
                          {t(lang, 'badge.current')}
                        </span>
                      )}
                    </div>
                    <div class="flex flex-col items-end gap-0.5 shrink-0">
                      <span class="text-xs text-slate-400 font-mono bg-slate-50 border border-slate-100 px-2 py-1 rounded-lg">
                        {lang === 'es' ? exp.periodEs : exp.periodEn}
                      </span>
                      {exp.startDate && (
                        <span class="text-xs font-semibold text-blue-600 bg-blue-50 border border-blue-100 px-2 py-0.5 rounded-lg">
                          {duration(exp.startDate, exp.endDate, lang)}
                        </span>
                      )}
                    </div>
                  </div>
                  <p class="text-slate-500 text-sm font-medium mb-3">{exp.company}</p>
                  <ul class="space-y-1.5 mb-3">
                    {(lang === 'es' ? exp.descriptionEs : exp.descriptionEn).map((line) => (
                      <li class="text-slate-600 text-sm flex gap-2.5 leading-snug">
                        <span class="text-blue-300 mt-0.5 shrink-0">▸</span>
                        <span>{line}</span>
                      </li>
                    ))}
                  </ul>
                  <div class="flex flex-wrap gap-1.5">
                    {exp.tech.map((tag) => (
                      <span class="bg-blue-50 text-blue-700 border border-blue-100 text-xs px-2.5 py-0.5 rounded-full font-mono">{tag}</span>
                    ))}
