---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import Layout from '../../layouts/Layout.astro';
import { t, type Lang } from '../../i18n/translations';

const rawData = JSON.parse(readFileSync(join(process.cwd(), 'src/data/cv.json'), 'utf8'));
const { personal, about, experiences, education, skillGroups, publications, languages, preferences, portfolio, references } = rawData;

export function getStaticPaths() {
  return [{ params: { lang: 'es' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };
const otherLang = lang === 'es' ? 'en' : 'es';
const title = `${personal.name} — ${personal.title}`;
const location = lang === 'es' ? personal.locationEs : personal.locationEn;

function initials(name: string) {
  return name.split(/\s+/).map(w => w[0]).slice(0, 2).join('').toUpperCase();
}

function totalExpYears(exps: any[]): number {
  const intervals = exps
    .filter(e => e.startDate)
    .map(e => ({
      start: new Date(e.startDate + '-01').getTime(),
      end: e.endDate ? new Date(e.endDate + '-01').getTime() : Date.now()
    }))
    .sort((a, b) => a.start - b.start);

  const merged: {start: number, end: number}[] = [];
  for (const iv of intervals) {
    if (!merged.length || iv.start > merged[merged.length - 1].end) {
      merged.push({ ...iv });
    } else {
      merged[merged.length - 1].end = Math.max(merged[merged.length - 1].end, iv.end);
    }
  }

  const totalMs = merged.reduce((acc, iv) => acc + (iv.end - iv.start), 0);
  return Math.floor(totalMs / (1000 * 60 * 60 * 24 * 365.25));
}

const expYears = totalExpYears(experiences);

function duration(startDate: string, endDate?: string, lang: string = 'es'): string {
  const s = new Date(startDate + '-01');
  const e = endDate ? new Date(endDate + '-01') : new Date();
  const months = (e.getFullYear() - s.getFullYear()) * 12 + (e.getMonth() - s.getMonth());
  const years = Math.floor(months / 12);
  const rem = months % 12;
  if (lang === 'es') {
    if (years > 0 && rem > 0) return `${years}a ${rem}m`;
    if (years > 0) return `${years} ${years === 1 ? 'año' : 'años'}`;
    return `${months} meses`;
  } else {
    if (years > 0 && rem > 0) return `${years}y ${rem}m`;
    if (years > 0) return `${years} ${years === 1 ? 'year' : 'years'}`;
    return `${months} months`;
  }
}
---

<Layout title={title} lang={lang}>

  <!-- ══════════ STICKY NAVBAR ══════════ -->
  <nav id="topnav" class="no-print fixed top-0 left-0 right-0 z-50 bg-slate-900/95 backdrop-blur border-b border-slate-800 h-16">
    <div class="flex items-center justify-between h-full px-4 lg:px-8 max-w-screen-2xl mx-auto">

      <!-- Nombre -->
      <a href="#about" class="text-white font-bold text-sm tracking-tight hover:text-blue-400 transition-colors">
        {personal.name}
      </a>

      <!-- Links secciones (desktop) -->
      <ul class="hidden md:flex items-center gap-0.5 text-sm font-medium">
        {[
          { id: 'about',           labelEs: 'Sobre mí',       labelEn: 'About' },
          { id: 'experience',      labelEs: 'Experiencia',    labelEn: 'Experience' },
          { id: 'education',       labelEs: 'Educación',      labelEn: 'Education' },
          { id: 'publications',    labelEs: 'Publicaciones',  labelEn: 'Publications' },
          { id: 'references',      labelEs: 'Referencias',    labelEn: 'References' },
        ].map(item => (
          <li>
            <a
              href={`#${item.id}`}
              data-section={item.id}
              class="nav-link px-3 py-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-700 transition-all border-b-2 border-transparent"
            >
              {lang === 'es' ? item.labelEs : item.labelEn}
            </a>
          </li>
        ))}
      </ul>

      <!-- PDF + móvil -->
      <div class="flex items-center gap-2">
        <button onclick="window.print()" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium text-slate-400 hover:text-white hover:bg-slate-800 transition-all">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          </svg>
          PDF
        </button>
        <!-- Móvil hamburger -->
        <button id="menu-btn" class="md:hidden p-1.5 rounded-md text-slate-400 hover:text-white hover:bg-slate-800 transition-all" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Menú móvil -->
    <div id="mobile-menu" class="hidden md:hidden bg-slate-900 border-t border-slate-800 px-4 py-2">
      {[
        { id: 'about',          labelEs: 'Sobre mí',      labelEn: 'About' },
        { id: 'experience',     labelEs: 'Experiencia',   labelEn: 'Experience' },
        { id: 'education',      labelEs: 'Educación',     labelEn: 'Education' },
        { id: 'publications',   labelEs: 'Publicaciones', labelEn: 'Publications' },
        { id: 'references',     labelEs: 'Referencias',   labelEn: 'References' },
      ].map(item => (
        <a
          href={`#${item.id}`}
          class="block py-2 text-sm text-slate-400 hover:text-white transition-colors"
          onclick="document.getElementById('mobile-menu').classList.add('hidden')"
        >
          {lang === 'es' ? item.labelEs : item.labelEn}
        </a>
      ))}
    </div>
  </nav>

  <div class="min-h-screen bg-slate-100 pt-16">
  <div class="flex flex-col lg:flex-row min-h-[calc(100vh-3rem)]">

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="w-full lg:w-96 xl:w-[30rem] shrink-0 bg-slate-900 lg:sticky lg:top-16 lg:h-[calc(100vh-4rem)] lg:overflow-y-auto">

      <div class="relative px-8 pt-10 pb-8 bg-gradient-to-b from-blue-950/60 to-transparent flex flex-col items-center text-center">
        <!-- Foto -->
        <a href={personal.website} target="_blank" rel="noopener" class="relative w-44 h-44 mb-5 block group cursor-pointer">
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-blue-500 to-blue-700 opacity-60 blur-md animate-pulse-slow"></div>
          <img
            src="/profile.jpg"
            alt={personal.name}
            class="relative w-44 h-44 rounded-full object-cover ring-2 ring-blue-500 ring-offset-2 ring-offset-slate-900 transition-transform duration-300 group-hover:scale-105"
            onerror="this.outerHTML='<div class=\'relative w-44 h-44 rounded-full bg-gradient-to-br from-blue-600 to-blue-800 ring-2 ring-blue-500 ring-offset-2 ring-offset-slate-900 flex items-center justify-center\'><span class=\'text-5xl font-bold text-white\'>AG</span></div>'"
          />
          <span class="absolute bottom-2 right-2 w-4 h-4 bg-emerald-400 rounded-full border-2 border-slate-900">
            <span class="absolute inset-0 rounded-full bg-emerald-400 animate-ping opacity-75"></span>
          </span>
        </a>

        <h1 class="text-2xl font-bold text-white leading-tight tracking-tight">{personal.name}</h1>
        <p class="text-blue-400 font-semibold text-sm mt-1">{personal.title}</p>
        <p class="text-slate-400 text-xs mt-2 flex items-center justify-center gap-1.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          {location}
        </p>

        <!-- Lang switcher -->
        <div class="flex gap-2 mt-5 no-print">
          <a href="/es" class={`px-3 py-1 rounded-full text-xs font-semibold transition-all ${lang === 'es' ? 'bg-blue-500 text-white shadow-lg shadow-blue-500/30' : 'bg-slate-800 text-slate-400 hover:bg-slate-700'}`}>ES</a>
          <a href="/en" class={`px-3 py-1 rounded-full text-xs font-semibold transition-all ${lang === 'en' ? 'bg-blue-500 text-white shadow-lg shadow-blue-500/30' : 'bg-slate-800 text-slate-400 hover:bg-slate-700'}`}>EN</a>
        </div>
